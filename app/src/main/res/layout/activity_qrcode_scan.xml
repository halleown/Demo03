<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible" />

    <com.example.demo03.scan.ViewfinderView
        android:id="@+id/myView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        app:vvFrameColor="#FF6D00"
        app:vvFrameCornerRadius="@dimen/_34dp"
        app:vvFrameCornerSize="@dimen/_32dp"
        app:vvFrameDrawable="@drawable/scan_outside_border"
        app:vvFrameGravity="center"
        app:vvFrameHeight="@dimen/_320dp"
        app:vvFrameWidth="@dimen/_320dp"
        app:vvLabelText="扫描"
        app:vvLabelTextColor="#FFFFFF"
        app:vvLabelTextLocation="bottom"
        app:vvLabelTextPadding="@dimen/_32dp"
        app:vvLabelTextSize="14dp"
        app:vvLaserAnimationInterval="40"
        app:vvLaserColor="#FF6D00"
        app:vvLaserGridColumn="17"
        app:vvLaserStyle="grid" />

    <ImageView
        android:id="@+id/ivFlashlight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/camera_scan_flashlight_margin_top"
        android:contentDescription="@null"
        android:src="@drawable/camera_scan_flashlight_selector"
        android:visibility="gone" />


    <RelativeLayout
        android:layout_width="match_parent"
        android:background="#D1BDBD"
        android:layout_height="@dimen/_50dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|top"
            android:padding="12dp"
            android:layout_alignParentStart="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_select_up_black"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_centerHorizontal="true"
            android:layout_width="wrap_content"
            android:textSize="@dimen/_24sp"
            android:layout_height="wrap_content"
            android:text="标题" />



    </RelativeLayout>

    <!-- 新增：加载转圈（相机没 STREAMING 前一直显示） -->
    <ProgressBar
        android:id="@+id/pbCameraLoading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="gone" />

</FrameLayout>