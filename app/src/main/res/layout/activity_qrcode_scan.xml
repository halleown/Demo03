<?xml version="1.0" encoding="UTF-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.king.view.viewfinderview.ViewfinderView
        android:id="@+id/viewfinderView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:vvFrameColor="#FF6D00"
        app:vvFrameCornerRadius="@dimen/_34dp"
        app:vvFrameCornerSize="@dimen/_32dp"
        app:vvFrameCornerStrokeWidth="@dimen/_34dp"
        app:vvFrameDrawable="@drawable/scan_outside_border"
        app:vvFrameGravity="center"
        app:vvFrameHeight="@dimen/_320dp"
        app:vvFrameRatio="0.7"
        app:vvFrameWidth="@dimen/_320dp"
        app:vvLabelText="扫描"
        app:vvLabelTextColor="#FFFFFF"
        app:vvLabelTextLocation="bottom"
        app:vvLabelTextPadding="@dimen/_32dp"
        app:vvLabelTextSize="14dp"
        app:vvLaserDrawableRatio="0.465"
        app:vvLaserDrawable="@drawable/scan_mask"
        app:vvLaserLineHeight="@dimen/_1dp"
        app:vvLaserStyle="image" />

    <ImageView
        android:id="@+id/ivFlashlight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/camera_scan_flashlight_margin_top"
        android:contentDescription="@null"
        android:src="@drawable/camera_scan_flashlight_selector" />
</FrameLayout>