<?xml version="1.0" encoding="UTF-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.example.demo03.scan.ViewfinderView
        android:id="@+id/myView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:vvFrameColor="#FF6D00"
        app:vvFrameCornerRadius="@dimen/_34dp"
        app:vvFrameCornerSize="@dimen/_32dp"
        app:vvFrameDrawable="@drawable/scan_outside_border"
        app:vvFrameGravity="center"
        app:vvFrameHeight="@dimen/_320dp"
        app:vvFrameWidth="@dimen/_320dp"
        app:vvLabelText="扫描"
        app:vvLabelTextColor="#FFFFFF"
        app:vvLabelTextLocation="bottom"
        app:vvLabelTextPadding="@dimen/_32dp"
        app:vvLabelTextSize="14dp"
        app:vvLaserAnimationInterval="40"
        app:vvLaserColor="#FF6D00"
        app:vvLaserGridColumn="17"
        app:vvLaserStyle="grid" />

    <ImageView
        android:id="@+id/ivFlashlight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/camera_scan_flashlight_margin_top"
        android:contentDescription="@null"
        android:src="@drawable/camera_scan_flashlight_selector"
        android:visibility="gone" />
</FrameLayout>